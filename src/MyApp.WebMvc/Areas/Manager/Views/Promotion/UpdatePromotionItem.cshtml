@using MyApp.Application.Features.PromotionItems.Requests
@model UpdatePromotionItemRequest
@{
    ViewData["title"] = "Update Promotion Item";
    ViewData["ActivePage"] = ManageNavPages.Promotion;
    var returnUrl = ViewData["ReturnUrl"] as string;
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-area="manager" asp-controller="promotion" asp-action="index" class="text-decoration-none">Khuyến mãi</a></li>
    <li class="breadcrumb-item"><a href="@returnUrl" class="text-decoration-none">Sản phẩm khuyến mãi</a></li>
    <li class="breadcrumb-item active" aria-current="page">Cập nhật</li>
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom py-3">
                <h4 class="mb-0 text-primary fw-bold">Cập nhật sản phẩm khuyến mãi</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="UpdatePromotionItem" method="post">
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="row g-4">
                        <div class="col-md-12">
                            <div class="d-flex justify-content-between align-items-end mb-2">
                                <label asp-for="OriginalPrice" class="form-label fw-medium mb-0">Giá gốc thời điểm yết</label>
                                <div class="form-check form-switch mb-0">
                                    <input type="checkbox" class="form-check-input" id="toggleOriginalPrice" role="switch" />
                                    <label class="form-check-label small" for="toggleOriginalPrice">Cho phép sửa giá</label>
                                </div>
                            </div>
                            <div class="input-group">
                                <input asp-for="OriginalPrice" class="form-control bg-light" id="OriginalPrice" readonly />
                                <span class="input-group-text">₫</span>
                            </div>
                            <span asp-validation-for="OriginalPrice" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-medium">Loại giảm giá</label>
                            <select asp-for="IsPercentageOverride" class="form-select">
                                <option value="">-- Chọn loại giảm --</option>
                                <option value="false">Giảm theo tiền</option>
                                <option value="true">Giảm theo %</option>
                            </select>
                            <span asp-validation-for="IsPercentageOverride" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="OverrideValue" class="form-label fw-medium">Giá trị giảm</label>
                            <input asp-for="OverrideValue" class="form-control" placeholder="Nhập số tiền hoặc %" />
                            <span asp-validation-for="OverrideValue" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-medium text-success">Giá sau giảm (Dự kiến)</label>
                            <div class="input-group input-group-lg">
                                <input type="text" id="finalPrice" class="form-control text-success fw-bold bg-light" readonly />
                                <span class="input-group-text bg-light text-success fw-bold">₫</span>
                            </div>
                        </div>

                        <div class="col-12 mt-4 pt-3 border-top d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4 fw-semibold">Cập nhật</button>
                            <a href="@returnUrl" class="btn btn-light px-4 border fw-semibold text-dark">Quay lại</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const overrideInput = document.getElementById("OverrideValue");
        const typeSelect = document.getElementById("IsPercentageOverride");
        const finalPriceInput = document.getElementById("finalPrice");
        const toggleOriginal = document.getElementById("toggleOriginalPrice");
        const originalInput = document.getElementById("OriginalPrice");

        function getOriginalPrice() {
            return parseFloat(originalInput.value || 0);
        }

        function calculate() {
            let originalPrice = getOriginalPrice();
            let overrideValue = parseFloat(overrideInput.value || 0);
            let isPercentage = typeSelect.value;
            let finalPrice = originalPrice;

            if (!isNaN(overrideValue) && overrideValue > 0) {
                if (isPercentage === "true") {
                    finalPrice = originalPrice * (1 - overrideValue / 100);
                } else if (isPercentage === "false") {
                    finalPrice = originalPrice - overrideValue;
                }
            }

            finalPrice = Math.max(finalPrice, 0);
            finalPriceInput.value = finalPrice.toLocaleString('vi-VN');
        }

        overrideInput.addEventListener("input", calculate);
        typeSelect.addEventListener("change", calculate);
        originalInput.addEventListener("input", calculate);

        calculate();

        toggleOriginal.addEventListener("change", function () {
            if (this.checked) {
                originalInput.removeAttribute("readonly");
                originalInput.classList.remove("bg-light");
            } else {
                originalInput.setAttribute("readonly", true);
                originalInput.classList.add("bg-light");
            }
        });
    </script>
}
