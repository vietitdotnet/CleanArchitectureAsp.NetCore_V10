@using MyApp.WebMvc.Areas.Manager.Models.Promotions

@model PromotionItemsViewModel
@{
    ViewData["title"] = "Create Promotion Items";
    ViewData["ActivePage"] = ManageNavPages.Promotion;
    
}

@section CSS {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        .select2-container .select2-selection--single {
            height: 38px;
            border: 1px solid #ced4da;
            border-radius: 0.375rem;
        }
        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 36px;
        }
        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 36px;
        }
    </style>
}

@section Breadcrumb {
  
    <li class="breadcrumb-item"><a asp-area="manager" asp-controller="promotion" asp-action="index">Khuyến mãi</a></li>
    <li class="breadcrumb-item active" aria-current="page">Sản phẩm khuyến mãi </li>
}
<div class="container-fluid p-0">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 text-primary">Danh sách Sản phẩm Khuyến mãi</h4>
        </div>
        <div class="card-body">
            
            <div class="mb-4 row">
                <div class="col-md-6">
                    <label class="form-label fw-semibold text-muted">Thêm sản phẩm mới</label>
                    <select id="product-select" class="form-select" style="width:100%"></select>
                </div>
               
            </div>

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle mb-0" id="promotion-table">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-end">Giảm</th>
                            <th class="text-center">Kiểu</th>
                            <th>Mã vạch</th>
                            <th class="text-end">Giá gốc</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.PromotionItems.Items.Any())
                        {
                            foreach (var item in Model.PromotionItems.Items)
                            {
                                <tr data-id="@item.Id">
                                    <td>
                                        <div class="fw-medium text-truncate" style="max-width: 250px;" title="@item.FullProductUnitName">
                                            @item.FullProductUnitName
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        <span class="text-danger fw-bold">
                                            @(item.OverrideValue?.ToString("N0") ?? "0")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge border text-dark @(item.IsPercentageOverride == true ? "border-info bg-info-subtle" : "border-warning bg-warning-subtle")">
                                            @(item.IsPercentageOverride == true ? "%" : "VNĐ")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-muted">@item.UnitBarcode</span>
                                    </td>
                                    <td class="text-end text-muted">
                                        @item.OriginalPrice.ToString("N0")
                                    </td>
                                    <td class="text-center">
                                        <div class="form-check form-switch d-flex justify-content-center">
                                            <input class="form-check-input toggle-active"
                                                   type="checkbox"
                                                   data-id="@item.Id"
                                            @(item.IsActive ? "checked" : "") />
                                        </div>
                                        <div class="status-text mt-1">
                                            <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                                                @(item.IsActive ? "Hoạt động" : "Tạm dừng")
                                            </span>
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="UpdatePromotionItem" asp-controller="promotion" asp-route-promotionId="@Model.PromotionId" asp-route-id="@item.Id" class="btn btn-outline-primary btn-edit" title="Sửa">
                                                Sửa
                                            </a>
                                            <button class="btn btn-outline-danger btn-delete"
                                                    data-id="@item.Id"
                                                    data-name="@item.FullProductUnitName">
                                                Xóa
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    Chưa có sản phẩm nào trong chương trình khuyến mãi này.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="card-footer bg-white py-3">
                <div class="d-flex justify-content-center">
                    @await Html.PartialAsync("_PartialPagination", Model.PromotionItems)
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger">Xác nhận xóa</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Bạn có chắc muốn xóa 
                <strong id="deleteItemName"></strong>
                khỏi chương trình khuyến mãi?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    Xóa
                </button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>


    <script>

        let index = 0;
        let selectedIds = new Set();

        $('#product-select').select2({
            placeholder: 'Tìm sản phẩm...',
            minimumInputLength: 2,
                ajax: {
                // Sử dụng Url.Action để tránh sai sót đường dẫn
                url: '@Url.Action("SearchProductUnits", "Promotion", new { area = "Manager" })',
                delay: 300, // debounce
                data: function (params) {
                return {
                term: params.term
                };
            },
                processResults: function (data) {
                 return {
                    results: data.map(x => ({
                    id: x.id,
                    text: x.text,
                    productName: x.productName,
                    unitName: x.unitName
                    }))
                 };
            }
            }
        });

        $('#product-select').on('select2:select', function (e) {
            const item = e.params.data;

            if (selectedIds.has(item.id)) {
            return; // tránh trùng
            }
            // redirect sang action
            const baseUrl = '@Url.Action("CreatePromotionItem", "Promotion", new { area = "Manager", id = Model.PromotionId })';

            const url = `${baseUrl}?unitId=${item.id}`;

            window.location.href = url;
        });

    </script>

     <script>

        $(document).on("change", ".toggle-active", function () {
        debugger
        const checkbox = $(this);
        const id = checkbox.data("id");
        const isActive = checkbox.is(":checked");

        // Hiệu ứng chờ (optional)
        checkbox.prop("disabled", true);
        debugger

        $.ajax({
                url: '@Url.Action("ToggleActive", "Promotion", new { area = "Manager" })',
                type: 'POST',
                // Gửi token nếu có [ValidateAntiForgeryToken] ở Controller
                data: {
                    id: id,
                    isActive: isActive
                },
                success: function (res) {
                    if (res.success) {
                        const row = checkbox.closest("td");
                        const badge = row.find(".status-text span");

                        if (isActive) {
                            badge.removeClass("bg-secondary").addClass("bg-success").text("Hoạt động");
                        } else {
                            badge.removeClass("bg-success").addClass("bg-secondary").text("Tạm dừng");
                        }
                    } else {
                        alert("Cập nhật thất bại!");
                        checkbox.prop("checked", !isActive);
                    }
                },
                error: function (xhr) {
                    console.error(xhr.responseText);
                    alert("Có lỗi xảy ra: " + xhr.status);
                    checkbox.prop("checked", !isActive);
                },
                complete: function() {
                    checkbox.prop("disabled", false);
                }
            });
        });
    </script>

    <script>
    let selectedId = null;
    let selectedRow = null;

    // click nút delete
    $(document).on("click", ".btn-delete", function () {
        selectedId = $(this).data("id");
        selectedRow = $(this).closest("tr");
       
        const name = $(this).data("name") || "sản phẩm này";
      
        $("#deleteItemName").text(name.length > 20 ? name.substring(0, 20) + "..." : name);
        const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
        modal.show();
    });

    // confirm delete
    $("#confirmDeleteBtn").on("click", function () {
        if (!selectedId) return;

        const btn = $(this);
        btn.prop("disabled", true).text("Đang xóa...");

        $.ajax({
            url: '@Url.Action("DeletePromotionItem", "Promotion", new { area = "Manager" })',
            type: 'POST',
            data: { id: selectedId },
            success: function (res) {
                if (res.success) {
                    // animation xóa row
                    selectedRow.fadeOut(300, function () {
                        $(this).remove();
                    });

                    // đóng modal
                    bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
                }
            },
            error: function () {
                alert("Xóa thất bại!");
            },
            complete: function () {
                btn.prop("disabled", false).text("Xóa");
                selectedId = null;
            }
        });
    });
</script>

    <partial name="_ValidationScriptsPartial" />

}