@using MyApp.Application.Features.Promotions.DTOs
@using MyApp.Domain.Paginations.Core
@using MyApp.Domain.Paginations.Parameters
@model PagedResponse<PromotionDto, PromotionParameters>

@{
    ViewData["title"] = "Promotions";
    ViewData["ActivePage"] = ManageNavPages.Promotion;
}

@section Breadcrumb {
    <li class="breadcrumb-item active" aria-current="page">Khuyến mãi</li>
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3 border-bottom">
        <h5 class="mb-0 text-primary fw-bold">Danh sách Khuyến mãi</h5>
        <div>
            <a asp-action="CreateFlashSale" asp-controller="Promotion" class="btn btn-primary btn-sm me-2 fw-semibold">
                + Flash Sale 
            </a>
            <a asp-action="CreateRegularPromotion" asp-controller="Promotion" class="btn btn-success btn-sm fw-semibold">
                + Regular Promotion 
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Tên</th>
                        <th>Loại</th>
                        <th>Giá trị</th>
                        <th>Giảm tối đa</th>
                        <th>Thời gian</th>
                        <th>Khung giờ</th>
                        <th>Phạm vi</th>
                        <th>Số lượng</th>
                        <th>Đã bán</th>
                        <th>Tình trạng</th>
                        <th class="text-center pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="ps-4 fw-medium text-dark">@item.Name</td>
                                <td>
                                    <span class="badge bg-info text-dark bg-opacity-10 border border-info px-2 py-1">
                                        @item.TextType
                                    </span>
                                </td>
                                <td>
                                    @if (item.IsPercentage)
                                    {
                                        <span class="text-success fw-bold">@item.Value%</span>
                                    }
                                    else
                                    {
                                        <span class="text-success fw-bold">
                                            @item.Value.ToString("N0") ₫
                                        </span>
                                    }
                                </td>
                                <td>
                                    <span class="text-muted">
                                        @(item.MaxDiscountAmount.HasValue ? item.MaxDiscountAmount.Value.ToString("N0") + " ₫" : "-")
                                    </span>
                                </td>
                                <td>
                                    <div class="text-muted" style="font-size: 0.85rem;">
                                        <div><span class="fw-medium text-dark">Từ:</span> @item.StartDate.ToString("dd/MM/yyyy HH:mm")</div>
                                        <div><span class="fw-medium text-dark">Đến:</span> @item.EndDate.ToString("dd/MM/yyyy HH:mm")</div>
                                    </div>
                                </td>
                                <td>
                                    @if (item.DailyStartTime.HasValue && item.DailyEndTime.HasValue)
                                    {
                                        <span class="badge bg-light text-dark border">
                                            @item.DailyStartTime.Value.ToString(@"hh\:mm") - @item.DailyEndTime.Value.ToString(@"hh\:mm")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsOnlineOnly)
                                    {
                                        <span class="badge bg-warning text-dark px-2 py-1">Online</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary px-2 py-1">All</span>
                                    }
                                </td>
                                <td>
                                    @(item.LimitQuantity.HasValue ? item.LimitQuantity.Value.ToString("N0") : "Không giới hạn")
                                </td>
                                <td>
                                    <span class="text-primary fw-bold">@item.SoldQuantity</span>
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success px-2 py-1">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary px-2 py-1">Inactive</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <a asp-action="AddPromotionItems" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary fw-semibold">
                                        Thêm sản phẩm
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="11" class="text-center py-4 text-muted">
                                Không có dữ liệu khuyến mãi
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white py-3">
        <div class="d-flex justify-content-center">
            @await Html.PartialAsync("_PartialPagination", Model)
        </div>
    </div>
</div>