@{
    Layout = "~/Views/Shared/_LayoutManager.cshtml";
    var statusMessage = TempData["StatusMessage"] as string;
}

@section CSS {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link href="~/css/sidebar.css" rel="stylesheet" />
    @RenderSection("CSS", required: false)
}

<div class="layout d-flex">
    <nav id="sidebar" class="sidebar d-flex flex-column">
    
        <!-- Header -->
        <div class="sidebar-header d-flex justify-content-between align-items-center">
            <span class="fw-bold fs-5">Manager</span>
            <button class="btn btn-sm text-white d-lg-none" id="closeSidebar">✕</button>
        </div>

        <!-- Scrollable menu -->
        <div class="sidebar-body">
            <partial name="_ManageNav.cshtml" />
        </div>

        <!-- Footer -->
        <div class="sidebar-footer mt-auto pt-3 small text-secondary">
            <hr class="border-secondary" />
            <div>© 2026 MyApp</div>
        </div>

    </nav>

    <!-- Overlay -->
    <div id="overlay"></div>

    <!-- Main -->
    <div class="content flex-grow-1">

        <!-- Page content -->
        <div class="container-fluid py-2">
            <!-- Breadcrumb -->
            <div class="mb-1">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0 bg-white px-3 py-2 rounded shadow-sm">
                        @RenderSection("Breadcrumb", required: false)
                    </ol>
                </nav>
            </div>

            <!-- Alert -->
            <partial name="_AlertMessage" model="@statusMessage" />

            <!-- Body -->
            <div class="mt-2">
                @RenderBody()
            </div>
        </div>
    </div>
</div>


@section Scripts {
    
    @RenderSection("Scripts", required: false)
    
      <script>
          const sidebar = document.getElementById('sidebar');
          const overlay = document.getElementById('overlay');

          document.getElementById('openSidebar').onclick = () => {
              sidebar.classList.add('active');
              overlay.classList.add('active');
          };

          document.getElementById('closeSidebar').onclick = () => {
              sidebar.classList.remove('active');
              overlay.classList.remove('active');
          };

          overlay.onclick = () => {
              sidebar.classList.remove('active');
              overlay.classList.remove('active');
          };
    </script>

}