@model ErrorViewModel
@{
    var area = ViewContext.RouteData.Values["area"]?.ToString();
    
    if (!string.IsNullOrEmpty(area))
    {
        Layout = $"~/Areas/{area}/Views/Shared/_Layout.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_Layout.cshtml";
    }
    var statusCode = Model?.StatusCode ?? 500;
    var errorCode = Model?.ErrorCode?.ToString() ?? "Unknown Error";

    ViewData["Title"] = "Lỗi hệ thống";
}

<div class="container text-center mt-5">
    <div class="card shadow-lg p-4">
        <h1 class="text-danger mb-3">@statusCode</h1>
        <h3 class="mb-3">⚠️ Oops ! @errorCode</h3>
        <p class="text-muted">
            @Model?.Message
        </p>

        @if (Model?.ShowRequestId == true)
        {
            <p class="mt-3">
                <small class="text-muted">
                    <strong>Request ID:</strong> @Model.RequestId
                </small>
            </p>
        }

        <div class="mt-4">
            <a href="javascript:history.back()" class="btn btn-outline-secondary me-2">
                ← Quay lại
            </a>

            <a href="/" class="btn btn-primary">
                Trang chủ
            </a>
        </div>
    </div>

    @if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
    {
        <div class="alert alert-warning mt-4 text-start">
            <strong>Development mode:</strong> Thông tin lỗi chi tiết sẽ hiển thị ở console/log.
        </div>
    }

</div>
